# Prevent access to ground truth and reference solutions during testing

# Ground truth files (contain expected answers)
**/ground_truth.json

# Reference implementations (contain complete solutions)
reference_*.py

# Starter code files (contain solutions to previous steps)
**/*_starter_code.py

# Validation scripts (generated by harness, may reveal expected values)
**/validate.py

# Benchmark files (contain test questions and answers)
benchmark_*.py

# Test harness infrastructure files
harness.py
actuarial_test_harness.py
actuarial_integration_test.py
generate_starter_code.py

# Node modules and dependencies
node_modules/

# Virtual environment
venv/

# Git files
.git/
.gitignore

# IDE configurations
.vscode/
.idea/

# Temporary and system files
*.pyc
__pycache__/
.DS_Store
*.log

